{
  "manifest_version": 3,
  "name": "InstaPageScrape v1.0",
  "version": "1.7",
  "description": "Auto-scrapes Instagram ecom brand profiles and exports a self-contained HTML catalog with images, reels, captions, prices and dates.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.cdninstagram.com/*",
    "*://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
